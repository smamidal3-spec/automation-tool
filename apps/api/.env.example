APP_ENV=development
DATABASE_URL=sqlite:///./automation.db

# Auth mode: dev | token
AUTH_MODE=dev
JWT_SECRET=
JWT_ALGORITHM=HS256
STATIC_TOKENS=admin-token:admin,editor-token:editor,viewer-token:viewer

RATE_LIMIT_PER_MINUTE=120

GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=
GITHUB_ORGS=
MANAGED_REPOS=
REPO_REFRESH_SECONDS=300
DRY_RUN_DEFAULT=true
BRANCH_PREFIX=automation
COMMIT_MESSAGE_TEMPLATE=chore(automation): update {key_path} in {environment_file}
REQUIRED_REVIEWERS=

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
