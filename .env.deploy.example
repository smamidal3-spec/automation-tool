# Copy this file to .env before docker compose up

# Required for real Git operations
GITHUB_TOKEN=
GITHUB_ORGS=
MANAGED_REPOS=

# Frontend URL where users open the tool
# Local: http://localhost:3000
# Production example: https://yaml-automation.yourcompany.com
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Must include frontend origin used by browsers
ALLOWED_ORIGINS=http://localhost:3000

# Keep true for simulation only; set false for real repo updates
DRY_RUN_DEFAULT=true

# Auth mode
# Use dev to avoid manual login fields in UI.
# Use token when you add a secure login/token delivery path.
AUTH_MODE=dev
STATIC_TOKENS=admin-token:admin,editor-token:editor,viewer-token:viewer
JWT_SECRET=

# Optional comma-separated GitHub usernames to auto-request as reviewers
REQUIRED_REVIEWERS=

RATE_LIMIT_PER_MINUTE=120
REPO_REFRESH_SECONDS=300
